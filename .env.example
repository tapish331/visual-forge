# Visual Forge local environment template.
# Copy this file to .env and fill in only the values you need.
# Visual Forge CLI commands load .env automatically from the repo root.
# Never commit .env.

# Hugging Face access token for downloading gated/private models.
# Public faster-whisper models may not require this, but keeping it here makes
# future model access explicit.
HF_TOKEN=

# Optional local media tool paths. Set these when PATH resolves the wrong binary
# or does not include FFmpeg/ffprobe.
VISUAL_FORGE_FFMPEG=C:\ffmpeg\bin\ffmpeg.exe
VISUAL_FORGE_FFPROBE=C:\ffmpeg\bin\ffprobe.exe

# Optional Visual Forge logging overrides.
VISUAL_FORGE_LOG_DIR=
VISUAL_FORGE_LOG_MAX_BYTES=
VISUAL_FORGE_LOG_BACKUP_COUNT=
VISUAL_FORGE_LOG_LEVEL=
VISUAL_FORGE_LOG_DISABLED=

# Reserved for future optional paid/API-backed providers.
# OPENAI_API_KEY=
