# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Local environment files
.env
.env.*
!.env.example

# Generated visual outputs
outputs/
models/

# Local rotating logs and process locks
logs/
projects/*/.visual-forge.lock*
assets/.visual-forge-assets.lock*

# Visual Forge project media and caches
projects/*/raw.mp4
projects/*/raw.mov
projects/*/final.mp4
projects/*/final.mov
projects/*/audio/
projects/*/cache/
projects/*/generated/
projects/*/renders/
projects/*/previews/
projects/*/chunk-previews/

# Externally referenced source media (scripts and JSON remain trackable)
inputs/**/*.mp4
inputs/**/*.mov
inputs/**/*.m4v
inputs/**/*.mkv
inputs/**/*.avi
inputs/**/*.webm
